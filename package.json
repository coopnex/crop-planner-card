{
  "name": "crop-planner-card",
  "type": "module",
  "version": "0.3.1",
  "packageManager": "yarn@1.22.22",
  "description": "A Lovelace card for the Crop Planner Home Assistant integration",
  "main": "dist/crop-planner-card.js",
  "scripts": {
    "start": "rollup -c rollup.config.dev.js --watch",
    "build": "yarn clean && yarn lint && yarn rollup",
    "clean": "rm -rf dist",
    "lint": "eslint src/**/*.ts",
    "rollup": "rollup -c",
    "dev": "rollup -c --watch",
    "release": "bash scripts/release.sh"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^26.0.0",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^15.2.0",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^11.1.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "esbuild": "^0.25.0",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.1",
    "rollup": "^4.20.0",
    "rollup-plugin-css-only": "^4.5.5",
    "rollup-plugin-esbuild": "^6.2.1",
    "rollup-plugin-serve": "^1.1.1",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@lit-labs/context": "0.4.1",
    "@lit-labs/motion": "1.0.7",
    "@lit-labs/observers": "2.0.2",
    "@lit-labs/virtualizer": "2.0.12",
    "custom-card-helpers": "2.0.0",
    "home-assistant-js-websocket": "9.6.0",
    "lit": "^3.3.2",
    "tslib": "^2.8.1"
  },
  "module": "boilerplate-card.js",
  "repository": "git@github.com:coopnex/crop-planner-card.git",
  "author": "Jaume Paternoy <paternoy@gmail.com>",
  "license": "MIT"
}
